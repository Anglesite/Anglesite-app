<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- v0: not sandboxed (Developer ID distribution). Sandbox comes in v2 with helper-tool architecture. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>

	<!-- Hardened Runtime: required for notarization. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<key>com.apple.security.cs.allow-dyld-environment-variables</key>
	<true/>
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>

	<!-- Spawning Node, wrangler, gh, claude as child processes. -->
	<key>com.apple.security.cs.allow-executable-page-protection</key>
	<true/>

	<!-- Apple Containerization framework (#69): boot local OCI containers. -->
	<key>com.apple.security.virtualization</key>
	<true/>
</dict>
</plist>
