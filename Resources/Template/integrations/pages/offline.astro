---
import BaseLayout from "../../src/layouts/BaseLayout.astro";
import { readConfig } from "../../scripts/config";

const siteName = readConfig("PWA_SITE_NAME") ?? "this site";
---

<BaseLayout title="Offline" description="You are currently offline.">
  <div class="offline-page">
    <h1>You're offline</h1>
    <p>It looks like your internet connection is unavailable. Pages you've visited before on {siteName} may still be accessible.</p>
    <nav aria-label="Available pages">
      <a href="/">Home page</a>
    </nav>
  </div>

  <style>
    .offline-page {
      text-align: center;
      padding: calc(var(--spacing-unit, 1rem) * 2) var(--spacing-unit, 1rem);
    }
    .offline-page h1 {
      margin-block-end: var(--spacing-unit, 1rem);
    }
    .offline-page p {
      color: var(--color-text-muted, #666);
      max-width: 32rem;
      margin-inline: auto;
      margin-block-end: calc(var(--spacing-unit, 1rem) * 1.5);
    }
    .offline-page nav {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
    .offline-page nav a {
      color: var(--color-primary, #2563eb);
    }
  </style>
</BaseLayout>
