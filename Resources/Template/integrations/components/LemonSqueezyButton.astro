---
/**
 * Lemon Squeezy overlay checkout — a link with the `lemonsqueezy-button` class
 * that the Lemon.js loader intercepts and opens as an in-page overlay.
 *
 * Generated by the lemon-squeezy integration.
 */
interface Props {
  href?: string;
  label?: string;
}
const { href = "#", label = "Buy Now" } = Astro.props;
---
<a href={href} class="lemonsqueezy-button buy-button">{label}</a>
<script is:inline src="https://assets.lemonsqueezy.com/lemon.js" defer></script>

<style>
  .buy-button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--color-primary, #2563eb);
    color: #fff;
    border-radius: 0.375rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
  }
  .buy-button:hover {
    opacity: 0.9;
  }
</style>
