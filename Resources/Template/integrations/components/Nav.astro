---
/**
 * Top navigation — up to four configurable label/path pairs. An item only
 * renders when both its label and path are set.
 *
 * Generated by the menu integration.
 */
interface Props {
  item1Label?: string;
  item1Path?: string;
  item2Label?: string;
  item2Path?: string;
  item3Label?: string;
  item3Path?: string;
  item4Label?: string;
  item4Path?: string;
}
const {
  item1Label, item1Path,
  item2Label, item2Path,
  item3Label, item3Path,
  item4Label, item4Path,
} = Astro.props;

const items = [
  { label: item1Label, path: item1Path },
  { label: item2Label, path: item2Path },
  { label: item3Label, path: item3Path },
  { label: item4Label, path: item4Path },
].filter((item): item is { label: string; path: string } => !!item.label && !!item.path);
---

{items.length > 0 && (
  <nav class="site-nav">
    <ul>
      {items.map((item) => (
        <li><a href={item.path}>{item.label}</a></li>
      ))}
    </ul>
  </nav>
)}

<style>
  .site-nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: calc(var(--spacing-unit, 1rem) * 1.25);
    margin: 0;
    padding: var(--spacing-unit, 1rem) 0;
    list-style: none;
  }
  .site-nav a {
    color: var(--color-text, #111);
    text-decoration: none;
    font-weight: 600;
  }
  .site-nav a:hover {
    text-decoration: underline;
  }
</style>
