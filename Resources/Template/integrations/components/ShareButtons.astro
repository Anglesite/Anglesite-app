---
/**
 * Social share buttons for a blog post — X, Mastodon, LinkedIn, and copy-link.
 * Mastodon has no single share endpoint, so the client script asks for (and
 * remembers, via localStorage) the visitor's own instance before opening
 * its compose UI.
 *
 * Generated by the share integration. Renders nothing when every network is
 * disabled.
 */
interface Props {
  title: string;
  twitter?: boolean;
  mastodon?: boolean;
  linkedin?: boolean;
  copyLink?: boolean;
}
const {
  title,
  twitter = false,
  mastodon = false,
  linkedin = false,
  copyLink = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;
const twitterHref = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(canonical)}`;
const linkedinHref = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonical)}`;

const anyEnabled = twitter || mastodon || linkedin || copyLink;
---

{anyEnabled && (
  <div class="share-buttons">
    <span class="share-buttons-label">Share:</span>
    {twitter && (
      <a href={twitterHref} target="_blank" rel="noopener noreferrer" class="share-button share-button--twitter">
        X (Twitter)
      </a>
    )}
    {mastodon && (
      <button type="button" class="share-button share-button--mastodon" data-share-mastodon
              data-share-text={title} data-share-url={canonical}>
        Mastodon
      </button>
    )}
    {linkedin && (
      <a href={linkedinHref} target="_blank" rel="noopener noreferrer" class="share-button share-button--linkedin">
        LinkedIn
      </a>
    )}
    {copyLink && (
      <button type="button" class="share-button share-button--copy" data-share-copy data-share-url={canonical}>
        Copy link
      </button>
    )}
  </div>

  <script is:inline>
    (function () {
      document.addEventListener("click", function (e) {
        var target = e.target.closest("[data-share-mastodon], [data-share-copy]");
        if (!target) return;
        if (target.hasAttribute("data-share-mastodon")) {
          var instance = window.localStorage.getItem("mastodon-share-instance");
          if (!instance) {
            instance = window.prompt("Your Mastodon instance (e.g. mastodon.social):");
            if (!instance) return;
            instance = instance.replace(/^https?:\/\//, "").replace(/\/$/, "");
            window.localStorage.setItem("mastodon-share-instance", instance);
          }
          var text = target.getAttribute("data-share-text") + " " + target.getAttribute("data-share-url");
          window.open("https://" + instance + "/share?text=" + encodeURIComponent(text), "_blank", "noopener,noreferrer");
        } else if (target.hasAttribute("data-share-copy")) {
          navigator.clipboard.writeText(target.getAttribute("data-share-url")).then(function () {
            var original = target.textContent;
            target.textContent = "Copied!";
            window.setTimeout(function () { target.textContent = original; }, 2000);
          });
        }
      });
    })();
  </script>
)}

<style>
  .share-buttons {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-block: var(--spacing-unit, 1rem);
  }
  .share-buttons-label {
    font-size: 0.9rem;
    color: var(--color-text-muted, #666);
  }
  .share-button {
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-sm, 0.25rem);
    border: 1px solid var(--color-text-muted, #999);
    background: transparent;
    color: var(--color-text, #111);
    font: inherit;
    font-size: 0.85rem;
    text-decoration: none;
    cursor: pointer;
  }
  .share-button:hover {
    background: var(--color-surface, #f5f5f5);
  }
</style>
