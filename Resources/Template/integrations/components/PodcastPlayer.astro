---
/**
 * Podcast episode player — embeds Spotify's or Transistor.fm's show player.
 *
 * Generated by the podcast integration.
 */
interface Props {
  provider?: "spotify" | "transistor";
  showId?: string;
  rssUrl?: string;
}
const { provider, showId, rssUrl } = Astro.props;

const src =
  provider === "spotify" && showId
    ? `https://open.spotify.com/embed/show/${showId}`
    : provider === "transistor" && showId
      ? `https://share.transistor.fm/e/${showId}`
      : undefined;
---

{src && (
  <iframe
    class="podcast-player"
    src={src}
    title="Podcast episodes"
    loading="lazy"
    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
  />
)}

{rssUrl && (
  <p class="podcast-rss">
    <a href={rssUrl}>Subscribe via RSS</a>
  </p>
)}

<style>
  .podcast-player {
    width: 100%;
    height: 232px;
    border: none;
    border-radius: var(--radius-lg, 0.5rem);
  }
  .podcast-rss {
    margin-block-start: var(--spacing-unit, 1rem);
  }
</style>
