---
/**
 * Privacy-friendly analytics script loader — Plausible, Fathom, or GA4.
 *
 * Generated by the tracking integration. Renders nothing when no recognized
 * provider is configured.
 */
interface Props {
  provider?: "plausible" | "fathom" | "ga4";
  domain?: string;
  siteId?: string;
  measurementId?: string;
}
const { provider, domain, siteId, measurementId } = Astro.props;
---

{provider === "plausible" && domain && (
  <script is:inline defer data-domain={domain} src="https://plausible.io/js/script.js"></script>
)}

{provider === "fathom" && siteId && (
  <script is:inline src="https://cdn.usefathom.com/script.js" data-site={siteId} defer></script>
)}

{provider === "ga4" && measurementId && (
  <>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`}></script>
    <script is:inline define:vars={{ measurementId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("js", new Date());
      gtag("config", measurementId);
    </script>
  </>
)}
