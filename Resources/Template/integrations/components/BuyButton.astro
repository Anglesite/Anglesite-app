---
/**
 * A single checkout link — Stripe Payment Link or Polar checkout URL.
 *
 * Generated by the buy-button integration.
 */
interface Props {
  href?: string;
  label?: string;
  provider?: "stripe" | "polar";
}
const {
  href = "#",
  label = "Buy Now",
  provider = "stripe",
} = Astro.props;
---
<a
  href={href}
  class:list={["buy-button", `buy-button--${provider}`]}
  target="_blank"
  rel="noopener noreferrer"
  data-buy-button-provider={provider}
>
  {label}
</a>

<style>
  .buy-button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--color-primary, #2563eb);
    color: #fff;
    border-radius: 0.375rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
  }
  .buy-button:hover {
    opacity: 0.9;
  }
</style>
