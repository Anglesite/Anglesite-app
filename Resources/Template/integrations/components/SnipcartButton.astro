---
/**
 * A single sample "add to cart" product button — the required Snipcart cart
 * container and script are injected globally at BaseLayout's body-end anchor
 * by the descriptor, not by this component.
 *
 * Generated by the snipcart integration.
 */
interface Props {
  name?: string;
  price?: string;
  url?: string;
  image?: string;
}
const {
  name = "Sample Product",
  price = "10.00",
  url = "/store",
  image,
} = Astro.props;
---
<button
  type="button"
  class="snipcart-add-item buy-button"
  data-item-id={name}
  data-item-price={price}
  data-item-url={url}
  data-item-name={name}
  data-item-image={image}
>
  Add to cart
</button>

<style>
  .buy-button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--color-primary, #2563eb);
    color: #fff;
    border: none;
    border-radius: 0.375rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    font: inherit;
  }
  .buy-button:hover {
    opacity: 0.9;
  }
</style>
