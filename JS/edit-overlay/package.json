{
  "name": "@anglesite/edit-overlay",
  "version": "0.1.0",
  "private": true,
  "description": "JS overlay injected into the WKWebView preview — hover/click/drop UI that posts edit messages to native.",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=iife --target=safari16 --outfile=../../Resources/edit-overlay/overlay.js",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  }
}
