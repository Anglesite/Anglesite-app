<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Configuration A — DevID baseline.
        No sandbox. Both restricted entitlements present. This is what `Anglesite` (DevID)
        would carry if it shipped the local Apple-Containerization path.

        Both com.apple.security.virtualization and com.apple.vm.networking are RESTRICTED
        entitlements — codesign will accept them ad-hoc for the spike, but a real signed
        build needs Apple to issue a provisioning profile granting them.
    -->
    <key>com.apple.security.app-sandbox</key><false/>
    <key>com.apple.security.cs.allow-jit</key><true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key><true/>
    <key>com.apple.security.virtualization</key><true/>
    <key>com.apple.vm.networking</key><true/>
</dict>
</plist>
