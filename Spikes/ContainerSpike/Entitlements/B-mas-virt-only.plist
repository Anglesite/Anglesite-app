<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Configuration B — MAS with com.apple.security.virtualization only.
        Sandboxed. Virtualization entitlement present, vmnet entitlement absent.
        Predicts: tier 1 ok, tier 2/3 fail at vmnet bridge or container network setup.
        This is the "best case Apple grants us .virtualization but not .vm.networking" scenario.
    -->
    <key>com.apple.security.app-sandbox</key><true/>
    <key>com.apple.security.network.client</key><true/>
    <key>com.apple.security.virtualization</key><true/>
</dict>
</plist>
