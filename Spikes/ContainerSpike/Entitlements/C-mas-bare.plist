<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Configuration C — MAS bare (mirrors current Resources/AnglesiteMAS.entitlements).
        Sandboxed, neither restricted entitlement. Predicts: tier 1 denied at the
        Virtualization framework's first sandbox check. This is the "what happens today
        if we just drop the Swift package in" scenario.
    -->
    <key>com.apple.security.app-sandbox</key><true/>
    <key>com.apple.security.network.client</key><true/>
</dict>
</plist>
