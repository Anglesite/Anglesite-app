<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template for xcodebuild -exportArchive. Consumed by scripts/notarize-dry-run.sh,
  which substitutes __TEAM_ID__ with the value of the TEAM_ID environment variable
  and writes the result to build/exportOptions.plist (gitignored).
-->
<plist version="1.0">
<dict>
    <key>method</key>
    <string>developer-id</string>
    <key>teamID</key>
    <string>__TEAM_ID__</string>
    <key>signingStyle</key>
    <string>manual</string>
</dict>
</plist>
